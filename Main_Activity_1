package com.example.myapplication;

import androidx.appcompat.app.AppCompatActivity;

import android.content.Intent;
import android.net.Uri;
import android.os.Bundle;
import android.view.View;
import android.widget.Button;
import android.widget.EditText;

public class MainActivity extends AppCompatActivity {

Button btn2,btn3,btn4;
EditText editText1,editText2,editText3,editText4;
    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main);


        btn2=findViewById(R.id.button1);
        btn3= findViewById(R.id.button2);
        btn4 = findViewById(R.id.button3);

editText2= findViewById(R.id.editText2);
editText1=findViewById(R.id.editText1);
editText3=findViewById(R.id.editText3);
editText4=findViewById(R.id.editText4);

        btn2.setOnClickListener(new View.OnClickListener() {
            @Override
            public void onClick(View v) {
           String et1 = editText1.getText().toString();
            int age = Integer.parseInt( editText2.getText().toString());

            Intent eIntent= new Intent(MainActivity.this, MainActivity2.class); // yeni çalışma adı mainactivity2 olduğu için onun classını aldık

              eIntent.putExtra("et1",et1); // giden text verisi
                eIntent.putExtra("age",age); // giden yas verisi
                startActivity(eIntent); // eıntent aktivetesini başlat dedik
            }
        });

        btn3.setOnClickListener(new View.OnClickListener() {
            @Override
            public void onClick(View v) {
                Uri telno = Uri.parse("tel: "+editText3.getText().toString()); // uri yönelndirme yapar.

                Intent iIntent= new Intent(Intent.ACTION_DIAL,telno);  // action dial telefon rehberine yönelndirir 
                startActivity(iIntent);
            }
        });
        btn4.setOnClickListener(new View.OnClickListener() {
            @Override
            public void onClick(View v) {
                Uri adress =Uri.parse( editText4.getText().toString());
                Intent sIntent= new Intent(Intent.ACTION_VIEW,adress); // action view ise sayfaya yönelndirir arama motorunda arama yapar.

                startActivity(sIntent);
            }
        });
    }
}
